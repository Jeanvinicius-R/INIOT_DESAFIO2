    {
        "id": "34a147403d4ee064",
        "type": "function",
        "z": "30bc97d7ce2367b0",
        "name": "Gerar CSV",
        "func": "var records = flow.get('records') || [];\n\nif (records.length === 0) {\n    msg.payload = 'Nenhum registro salvo ainda.';\n    msg.statusCode = 204;\n    return msg;\n}\n\nvar linhas = ['ID,Data/Hora,Timestamp ISO,Temperatura (C),Umidade (%)'];\nrecords.forEach(function(r) {\n    linhas.push([\n        r.id,\n        '\"' + r.datetime + '\"',\n        '\"' + r.timestamp + '\"',\n        r.temperature,\n        r.humidity\n    ].join(','));\n});\n\nvar ts = new Date().toISOString().slice(0,19).replace(/[T:]/g,'-');\nmsg.payload = linhas.join('\\n');\nmsg.headers = {\n    'Content-Type': 'text/csv; charset=utf-8',\n    'Content-Disposition': 'attachment; filename=\"iiot_desafio2_' + ts + '.csv\"'\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 420,
