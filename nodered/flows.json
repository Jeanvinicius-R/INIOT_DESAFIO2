    {
        "id": "6e82f3a4fd92d495",
        "type": "function",
        "z": "30bc97d7ce2367b0",
        "name": "Separar temp e umidade",
        "func": "var p = msg.payload;\nif (typeof p === 'string') {\n    try { p = JSON.parse(p); } catch(e) { return null; }\n}\n\nvar temp = p.temperature != null ? p.temperature : p.temperatura != null ? p.temperatura : p.temp != null ? p.temp : p.t != null ? p.t : null;\nvar hum  = p.humidity    != null ? p.humidity    : p.umidade    != null ? p.umidade    : p.hum  != null ? p.hum  : p.h != null ? p.h : null;\n\nif (temp === null && hum === null) return null;\n\nflow.set('lastTemp', temp !== null ? parseFloat(temp) : flow.get('lastTemp'));\nflow.set('lastHum',  hum  !== null ? parseFloat(hum)  : flow.get('lastHum'));\n\nvar msgTemp = { payload: temp !== null ? parseFloat(parseFloat(temp).toFixed(1)) : null };\nvar msgHum  = { payload: hum  !== null ? parseFloat(parseFloat(hum).toFixed(1))  : null };\n\nreturn [msgTemp, msgHum];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "flow.set('lastTemp', null);\nflow.set('lastHum', null);\nflow.set('records', []);",
        "finalize": "",
        "libs": [],
