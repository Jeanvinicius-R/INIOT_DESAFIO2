    {
        "id": "833820671c5a6ab3",
        "type": "function",
        "z": "30bc97d7ce2367b0",
        "name": "Salvar registro",
        "func": "var temp = flow.get('lastTemp');\nvar hum  = flow.get('lastHum');\n\nif (temp === null || temp === undefined) {\n    node.status({fill:'yellow', shape:'ring', text:'sem dados ainda'});\n    return null;\n}\n\nvar records = flow.get('records') || [];\nvar now = new Date();\n\nrecords.push({\n    id:          records.length + 1,\n    datetime:    now.toLocaleString('pt-BR'),\n    timestamp:   now.toISOString(),\n    temperature: parseFloat(temp.toFixed(2)),\n    humidity:    hum !== null ? parseFloat(hum.toFixed(2)) : ''\n});\n\nflow.set('records', records);\nnode.status({fill:'green', shape:'dot', text: records.length + ' registros — ' + now.toLocaleTimeString('pt-BR')});\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 220,
        "wires": [
            []
        ]
    },
